{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/process.ts": {
      "maxDuration": 60
    },
    "api/analyze.ts": {
      "maxDuration": 60
    },
    "api/export.ts": {
      "maxDuration": 30
    }
  }
}
